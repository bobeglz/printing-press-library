{
  "manifest_version": "0.3",
  "name": "motohunt-pp-mcp",
  "display_name": "Motohunt",
  "version": "4.2.2",
  "description": "Search motorcycle and ATV listings with MotoHunt price research (MSRP/ALP/deal rating) — no API, scrapes server-rendered HTML",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/motohunt-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/motohunt-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
